{
  "name": "traste",
  "description": "A library for rendering guitar and ukulele fretboards as SVG elements.",
  "version": "1.0.0",
  "author": "Ramiro Gómez (https://ramiro.org/)",
  "bugs": {
    "url": "https://github.com/yaph/traste/issues",
    "email": "code@ramiro.org"
  },
  "dependencies": {
    "@tonaljs/tonal": "^4.10.0",
    "cromatica": "^0.3.0",
    "d3-selection": "^3.0.0"
  },
  "devDependencies": {
    "@types/d3-selection": "^3.0.11",
    "esbuild": "^0.19.12",
    "typescript": "^5.0.0"
  },
  "directories": {
    "example": "examples"
  },
  "files": [
    "src/**/*",
    "dist/**/*"
  ],
  "homepage": "https://github.com/yaph/traste",
  "keywords": [
    "fingerboard",
    "fret",
    "fretboard",
    "guitar",
    "instrument",
    "music",
    "svg",
    "uke",
    "ukulele"
  ],
  "license": "MIT",
  "main": "dist/traste.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaph/traste.git"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "npm run build:js && npm run build:types",
    "build:js": "esbuild src/index.ts --outfile=dist/traste.js --bundle --format=iife --global-name=traste",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist src/index.ts",
    "serve": "esbuild src/index.ts --outfile=dist/traste.js --bundle --format=iife --global-name=traste --watch --servedir=."
  },
  "types": "dist/traste.d.ts"
}
